{
  "version": 3,
  "name": "VACE inpaint/stitch (vlo)",
  "nodes": {
    "98": {
      "selection": {
        "export_fps": 16,
        "frame_step": 4,
        "max_frames": 81
      }
    },
    "101": {}
  },
  "validation": {
    "inputs": []
  },
  "derived_widgets": [],
  "output_injections": {},
  "slots": {},
  "pipeline": [
    {
      "id": "mask_processing",
      "kind": "mask_processing",
      "after": [
        "aspect_ratio"
      ],
      "targets": [
        {
          "source": {
            "node_id": "98",
            "param": "file"
          },
          "mask": {
            "node_id": "101",
            "param": "file"
          },
          "mask_type": "binary",
          "purpose": "video"
        }
      ],
      "controls": [
        {
          "key": "crop_mode",
          "label": "Mask crop mode",
          "value_type": "enum",
          "expose": "widget",
          "options": [
            "crop",
            "full"
          ],
          "default": "crop"
        },
        {
          "key": "crop_dilation",
          "label": "Mask crop padding",
          "value_type": "float",
          "expose": "widget",
          "control": "slider",
          "slider_display": "percent",
          "min": 0,
          "max": 0.5,
          "step": 0.01,
          "default": 0.1
        },
        {
          "key": "source_video_treatment",
          "label": "Transparency handling",
          "value_type": "enum",
          "expose": "widget",
          "default": "preserve_transparency"
        }
      ]
    },
    {
      "id": "aspect_ratio",
      "kind": "aspect_ratio",
      "enabled": true,
      "config": {
        "stride": 16,
        "search_steps": 2,
        "resolutions": [
          480,
          720
        ],
        "postprocess": {
          "enabled": true,
          "mode": "stretch_exact",
          "apply_to": "all_visual_outputs"
        }
      },
      "targets": [
        {
          "width": {
            "node_id": "104",
            "param": "resize_type.width"
          },
          "height": {
            "node_id": "104",
            "param": "resize_type.height"
          }
        },
        {
          "width": {
            "node_id": "105",
            "param": "resize_type.width"
          },
          "height": {
            "node_id": "105",
            "param": "resize_type.height"
          }
        }
      ],
      "controls": [
        {
          "key": "target_resolution",
          "label": "Resolution",
          "value_type": "int",
          "expose": "widget",
          "options": [
            480,
            720
          ],
          "default": 720
        },
        {
          "key": "target_aspect_ratio",
          "value_type": "string",
          "expose": "hidden"
        }
      ]
    }
  ]
}
