# Keep the repo-root Docker context tiny.
# The Runpod image builds app code from the local git ref plus the startup script.
*
!.git
!.git/**
!package.json
!package-lock.json
!frontend
!frontend/package.json
!frontend/package-lock.json
!backend
!backend/pyproject.toml
!backend/uv.lock
!backend/requirements.txt
!deploy
!deploy/runpod
!deploy/runpod/**
